# 依赖（默认忽略；但前端完整依赖按要求提交 git，便于新任务 clone 即构建）
node_modules/
!frontend/node_modules/
backend/__pycache__/
__pycache__/
*.pyc

# 构建产物（可重建）
frontend/dist/

# 日志
*.log
/backend/*.log

# 编辑器/IDE
.idea/
.vscode/
.DS_Store

# 虚拟环境
.venv/
venv/

# 本地密钥与数据库文件（真实 .env 禁止入库；.env.example 可入库作为模板）
.env
.env.local
*.db
*.sqlite3

